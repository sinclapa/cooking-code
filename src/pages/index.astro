---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { calculateReadingTime, formatReadingTime } from '../utils/readingTime';

const blogPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const recentPosts = blogPosts.slice(0, 3);
const recentArticles = articles.slice(0, 3);
---

<BaseLayout title="Home" description="Cooking Code — developer blog and technical articles. Fresh ideas, well done.">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-badge">🍳 Welcome to Cooking Code</div>
      <div class="hero-title-row">
        <img src="/branding/cc-logo-white-simple.svg" alt="Cooking Code logo" class="hero-logo" />
        <h1 class="hero-title">
          Code that's<br />
          <span class="gradient-text">well done.</span>
        </h1>
      </div>
      <p class="hero-subtitle">
        Developer articles, tutorials, and opinions — served fresh. Explore AI tooling,
        modern web development, and the occasional spicy take.
      </p>
      <div class="hero-actions">
        <a href="/blog" class="btn btn--primary">Read the Blog</a>
        <a href="/articles" class="btn btn--ghost">Browse Articles</a>
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">
          <span class="section-icon">📝</span> Latest Posts
        </h2>
        <a href="/blog" class="section-link">View all →</a>
      </div>
      <div class="card-grid">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.slug}`} class="card card--blog">
            <div class="card-meta">
              <span class="tag tag--blog">Blog</span>
              <span class="card-read-time">{formatReadingTime(calculateReadingTime(post.body))}</span>
              <time class="card-date" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h3 class="card-title">{post.data.title}</h3>
            <p class="card-desc">{post.data.description}</p>
            <div class="card-tags">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="pill">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">
          <span class="section-icon">📖</span> Latest Articles
        </h2>
        <a href="/articles" class="section-link">View all →</a>
      </div>
      <div class="card-grid">
        {recentArticles.map((article) => (
          <a href={`/articles/${article.slug}`} class="card card--article">
            <div class="card-meta">
              <span class="tag tag--article">Article</span>
              <span class="card-read-time">{formatReadingTime(calculateReadingTime(article.body))}</span>
              <span class={`badge badge--${article.data.difficulty}`}>{article.data.difficulty}</span>
              <time class="card-date" datetime={article.data.pubDate.toISOString()}>
                {article.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
            </div>
            <h3 class="card-title">{article.data.title}</h3>
            <p class="card-desc">{article.data.description}</p>
            <div class="card-tags">
              {article.data.tags.slice(0, 3).map((tag) => (
                <span class="pill">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 6rem 0 5rem;
    text-align: center;
    background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(255, 107, 53, 0.12) 0%, transparent 70%);
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.3em 1em;
    margin-bottom: 1.5rem;
    color: var(--color-text-muted);
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .hero-title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .hero-logo {
    height: clamp(6.6rem, 17.6vw, 11rem);
    width: auto;
    flex-shrink: 0;
  }

  .hero-title-row .hero-title {
    margin-bottom: 0;
    text-align: left;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-accent) 0%, #ff3cac 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.75rem 2rem;
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-weight: 600;
    transition: all 0.2s;
    cursor: pointer;
    text-decoration: none;
  }

  .btn--primary {
    background: var(--color-accent);
    color: #fff;
  }

  .btn--primary:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 107, 53, 0.3);
  }

  .btn--ghost {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn--ghost:hover {
    background: var(--color-surface-raised);
    color: var(--color-text);
    transform: translateY(-2px);
  }

  /* Sections */
  .section {
    padding: 4rem 0;
    border-top: 1px solid var(--color-border);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 1.5rem;
    margin: 0;
  }

  .section-icon {
    margin-right: 0.25rem;
  }

  .section-link {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .section-link:hover {
    color: var(--color-accent);
  }

  /* Card Grid */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .card--blog:hover {
    border-color: var(--color-accent-blog);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(34, 211, 167, 0.08);
  }

  .card--article:hover {
    border-color: var(--color-accent-article);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(124, 92, 191, 0.1);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin-left: auto;
  }

  .card-read-time {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .card-title {
    font-size: 1.1rem;
    margin: 0 0 0.6rem;
    line-height: 1.4;
    color: var(--color-text);
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    flex: 1;
    margin: 0;
  }

  .card-tags {
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .pill {
    font-size: 0.72rem;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.15em 0.65em;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .hero-title-row {
      gap: 0.75rem;
      align-items: flex-start;
    }

    .hero-logo {
      height: clamp(5.6rem, 24vw, 7.2rem);
      margin-top: 0.25rem;
    }
  }
</style>
