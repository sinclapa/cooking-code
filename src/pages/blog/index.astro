---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog" description="Developer thoughts, tutorials, and opinions from the Cooking Code team.">
  <div class="page-header">
    <div class="container">
      <p class="page-eyebrow">📝 Writing</p>
      <h1 class="page-title">Blog</h1>
      <p class="page-subtitle">
        Thoughts, tutorials, and the occasional deep-dive from the Cooking Code team.
      </p>
    </div>
  </div>

  <div class="container posts-list">
    {posts.map((post) => (
      <a href={`/blog/${post.slug}`} class="post-row">
        <div class="post-row-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
          </time>
          {post.data.tags.slice(0, 2).map((tag) => (
            <span class="pill">{tag}</span>
          ))}
        </div>
        <div class="post-row-body">
          <h2 class="post-row-title">{post.data.title}</h2>
          <p class="post-row-desc">{post.data.description}</p>
        </div>
        <span class="post-row-arrow" aria-hidden="true">→</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(180deg, var(--color-surface) 0%, transparent 100%);
    border-bottom: 1px solid var(--color-border);
    padding: 4rem 0 3rem;
    margin-bottom: 3rem;
  }

  .page-eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent-blog);
    margin: 0 0 0.75rem;
  }

  .page-title {
    margin-bottom: 0.75rem;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-bottom: 4rem;
  }

  .post-row {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    align-items: start;
    gap: 1.5rem;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-text);
    transition: all 0.2s;
  }

  .post-row:hover {
    padding-left: 0.5rem;
  }

  .post-row:hover .post-row-title {
    color: var(--color-accent-blog);
  }

  .post-row:hover .post-row-arrow {
    transform: translateX(4px);
    color: var(--color-accent-blog);
  }

  .post-row-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.2rem;
  }

  .post-row-meta time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .post-row-body {
    flex: 1;
  }

  .post-row-title {
    font-size: 1.2rem;
    margin: 0 0 0.5rem;
    line-height: 1.4;
    transition: color 0.2s;
  }

  .post-row-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  .post-row-arrow {
    font-size: 1.25rem;
    color: var(--color-border);
    transition: all 0.2s;
    padding-top: 0.2rem;
  }

  .pill {
    font-size: 0.72rem;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.15em 0.65em;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .post-row {
      grid-template-columns: 1fr auto;
    }

    .post-row-meta {
      grid-column: 1 / -1;
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
</style>
