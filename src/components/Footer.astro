---
const year = new Date().getFullYear();
const buildVersion = import.meta.env.PUBLIC_BUILD_VERSION;
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-brand">Cooking<strong class="footer-brand-accent">Code</strong> — code that's well done.</p>
    <p class="footer-copy">&copy; {year} Cooking Code. Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>.</p>
    <p class="footer-version">{buildVersion}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
    padding: 2.5rem 0;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .footer-brand {
    margin: 0;
    font-size: 1rem;
    color: var(--color-text);
    font-weight: 400;
  }

  .footer-brand-accent {
    color: var(--color-accent);
  }

  .footer-copy {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-copy a {
    color: var(--color-accent);
  }

  .footer-version {
    margin: 0;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-text-muted);
    opacity: 0.5;
  }
</style>
