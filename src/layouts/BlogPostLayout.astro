---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import { formatReadingTime } from '../utils/readingTime';

interface Props {
  post: CollectionEntry<'blog'>;
  readingTimeMinutes: number;
}

const { post, readingTimeMinutes } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags, author } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={heroImage}>
  <article class="post-page">
    <div class="post-hero">
      {heroImage && (
        <div class="hero-image-wrapper">
          <img src={heroImage} alt={title} class="hero-image" />
        </div>
      )}
      <div class="container post-hero-content">
        <div class="post-meta-top">
          <span class="tag tag--blog">Blog</span>
          {tags.map((tag) => <span class="tag tag--neutral">{tag}</span>)}
        </div>
        <h1 class="post-title">{title}</h1>
        <p class="post-description">{description}</p>
        <div class="post-byline">
          <span class="post-author">{author}</span>
          <span class="divider">·</span>
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span class="divider">·</span>
          <span>{formatReadingTime(readingTimeMinutes)}</span>
          {formattedUpdated && (
            <>
              <span class="divider">·</span>
              <span class="updated-label">Updated {formattedUpdated}</span>
            </>
          )}
        </div>
      </div>
    </div>

    <div class="container">
      <div class="post-body content-width">
        <slot />
        <div class="post-footer">
          <a href="/blog" class="back-link">← Back to Blog</a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-page {
    padding-bottom: 4rem;
  }

  .post-hero {
    background: linear-gradient(180deg, var(--color-surface) 0%, transparent 100%);
    padding: 3rem 0;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-image-wrapper {
    max-width: var(--max-width);
    margin: 0 auto 2rem;
    padding: 0 1.5rem;
  }

  .hero-image {
    width: 100%;
    max-height: 400px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .post-hero-content {
    max-width: var(--content-width);
  }

  .post-meta-top {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .tag--neutral {
    color: var(--color-text-muted);
    border-color: var(--color-border);
  }

  .post-title {
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    margin-top: 0.75rem;
    line-height: 1.6;
  }

  .post-byline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .post-author {
    font-weight: 600;
    color: var(--color-accent-blog);
  }

  .divider {
    color: var(--color-border);
  }

  .updated-label {
    font-style: italic;
  }

  .post-body {
    font-size: 1.05rem;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-accent);
  }
</style>
