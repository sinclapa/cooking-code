{
  "globalHeaders": {
    "Content-Security-Policy": "upgrade-insecure-requests",
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "navigationFallback": {
    "rewrite": "/404",
    "exclude": ["/_astro/*", "/favicon.*", "*.css", "*.js", "*.png", "*.svg"]
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/404",
      "statusCode": 404
    }
  }
}
